@using SampleDataRepository
@using System.Reflection

<div class="grid-control">
    @if (_isLoading && _data is null)
    {
        <div class="grid-loading">
            <span class="grid-spinner"></span>
            <span>Loading&hellip;</span>
        </div>
    }
    else if (_columns is not null && _data is not null)
    {
        <div class="grid-pagination">
            <button class="grid-page-arrow" disabled="@(_currentPage <= 1 || _isLoading)" @onclick="PreviousPageAsync" aria-label="Previous page">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="15 18 9 12 15 6" />
                </svg>
            </button>
            <span class="grid-page-number">@_currentPage</span>
            <button class="grid-page-arrow" disabled="@(!_hasNextPage || _isLoading)" @onclick="NextPageAsync" aria-label="Next page">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="9 6 15 12 9 18" />
                </svg>
            </button>

            @if (_filterableColumns is { Count: > 0 })
            {
                <button class="grid-filter-icon" @onclick="OpenFilterModal" aria-label="Filter">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3" />
                    </svg>
                </button>
            }
        </div>

        <div class="grid-table-wrapper">
            <table class="grid-table">
                <thead>
                    <tr>
                        @foreach (var col in _columns)
                        {
                            <th>@col</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @if (_data.Count == 0)
                    {
                        <tr>
                            <td colspan="@_columns.Count" class="grid-empty">No data available.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var row in _data)
                        {
                            <tr @key="row">
                                @foreach (var col in _columns)
                                {
                                    <td data-label="@col">@GetCellValue(row, col)</td>
                                }
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    }

    @if (_showModal && _filterRows is not null)
    {
        <div class="grid-modal-backdrop" @onclick="CloseFilterModal">
            <div class="grid-modal" @onclick:stopPropagation="true">
                <div class="grid-modal-header">
                    <h3>Filter</h3>
                    <button class="grid-modal-close" @onclick="CloseFilterModal" aria-label="Close">&times;</button>
                </div>
                <div class="grid-modal-body">
                    <table class="grid-filter-table">
                        <thead>
                            <tr>
                                <th>Column</th>
                                <th>Condition</th>
                                <th>Value</th>
                            </tr>
                        </thead>
                        <tbody>
                            @for (var i = 0; i < _filterRows.Length; i++)
                            {
                                var index = i;
                                <tr>
                                    <td class="grid-filter-col-name">@_filterRows[index].Column</td>
                                    <td>
                                        <select class="grid-filter-select"
                                                value="@_filterRows[index].Operator"
                                                @onchange="(e) => OnOperatorChanged(e, index)">
                                            <option value="Equal">Equal</option>
                                            <option value="NotEqual">Not Equal</option>
                                            <option value="Contains">Contains</option>
                                            <option value="GreaterThan">Greater Than</option>
                                            <option value="LessThan">Less Than</option>
                                            <option value="GreaterThanOrEqual">&ge; (GTE)</option>
                                            <option value="LessThanOrEqual">&le; (LTE)</option>
                                        </select>
                                    </td>
                                    <td>
                                        <input class="grid-filter-input" type="text"
                                               value="@_filterRows[index].Value"
                                               @onchange="(e) => OnValueChanged(e, index)" />
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <div class="grid-modal-footer">
                    <button class="grid-modal-btn grid-modal-btn-clear" @onclick="ClearFilterValues">Clear</button>
                    <button class="grid-modal-btn grid-modal-btn-save" @onclick="SaveFiltersAsync">Save</button>
                </div>
            </div>
        </div>
    }
</div>

@typeparam T where T : class

@code {
    [Parameter, EditorRequired]
    public IGridDataRepository<T> DataRepository { get; set; } = default!;

    [Parameter]
    public int PageSize { get; set; } = 10;

    private IReadOnlyList<string>? _columns;
    private IReadOnlyList<string>? _filterableColumns;
    private List<T>? _data;
    private Dictionary<string, PropertyInfo>? _propertyCache;
    private int _currentPage = 1;
    private bool _hasNextPage;
    private bool _isLoading;

    private bool _showModal;
    private FilterRowModel[]? _filterRows;

    private class FilterRowModel
    {
        public string Column { get; set; } = string.Empty;
        public string Operator { get; set; } = "Equal";
        public string Value { get; set; } = string.Empty;
    }

    protected override async Task OnInitializedAsync()
    {
        _columns = DataRepository.GetColumnNames();
        _filterableColumns = DataRepository.Capabilities.Filter;
        _propertyCache = typeof(T)
            .GetProperties(BindingFlags.Public | BindingFlags.Instance)
            .Where(p => _columns.Contains(p.Name))
            .ToDictionary(p => p.Name);

        await LoadPageAsync();
    }

    private async Task LoadPageAsync()
    {
        _isLoading = true;
        StateHasChanged();

        var results = await DataRepository.GetDataAsync(_currentPage, PageSize);
        _data = results;
        _hasNextPage = results.Count == PageSize;

        _isLoading = false;
    }

    private async Task NextPageAsync()
    {
        _currentPage++;
        await LoadPageAsync();
    }

    private async Task PreviousPageAsync()
    {
        if (_currentPage > 1)
        {
            _currentPage--;
            await LoadPageAsync();
        }
    }

    private void OpenFilterModal()
    {
        if (_filterableColumns is null) return;

        var existing = DataRepository.FilterColumns
            .ToDictionary(f => f.Column, f => f);

        _filterRows = _filterableColumns.Select(col =>
        {
            if (existing.TryGetValue(col, out var fc))
                return new FilterRowModel { Column = col, Operator = fc.Operator, Value = fc.Value };
            return new FilterRowModel { Column = col };
        }).ToArray();

        _showModal = true;
    }

    private void CloseFilterModal() => _showModal = false;

    private void OnOperatorChanged(ChangeEventArgs e, int index)
    {
        _filterRows![index].Operator = e.Value?.ToString() ?? "Equal";
    }

    private void OnValueChanged(ChangeEventArgs e, int index)
    {
        _filterRows![index].Value = e.Value?.ToString() ?? string.Empty;
    }

    private void ClearFilterValues()
    {
        if (_filterRows is null) return;
        foreach (var row in _filterRows)
        {
            row.Value = string.Empty;
        }
    }

    private async Task SaveFiltersAsync()
    {
        DataRepository.FilterColumns.Clear();
        if (_filterRows is not null)
        {
            foreach (var row in _filterRows)
            {
                if (!string.IsNullOrWhiteSpace(row.Value))
                    DataRepository.FilterColumns.Add(new FilterColumn(row.Column, row.Operator, row.Value));
            }
        }

        _showModal = false;
        _currentPage = 1;
        await LoadPageAsync();
    }

    private string GetCellValue(T row, string columnName)
    {
        if (_propertyCache is null || !_propertyCache.TryGetValue(columnName, out var prop))
            return string.Empty;

        var value = prop.GetValue(row);
        return value switch
        {
            DateTime dt => dt.ToShortDateString(),
            null => string.Empty,
            _ => value.ToString() ?? string.Empty
        };
    }
}
