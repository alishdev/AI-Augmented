@using SampleDataRepository
@using System.Reflection
@using FluentValidation
@using GridControlStepByStep.Services
@inject GridStateService GridState

<div class="grid-control @(_isDragging ? "grid-resizing" : "")" @onkeydown="OnKeyDown" tabindex="0">
    @if (_columns is not null)
    {
        <div class="grid-toolbar-bar">
            <div class="grid-pagination">
                <button class="grid-page-arrow" disabled="@(_currentPage <= 1 || _isLoading)" @onclick="PreviousPageAsync" aria-label="Previous page">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="15 18 9 12 15 6" />
                    </svg>
                </button>
                <span class="grid-page-number">@_currentPage</span>
                <button class="grid-page-arrow" disabled="@(!_hasNextPage || _isLoading)" @onclick="NextPageAsync" aria-label="Next page">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="9 6 15 12 9 18" />
                    </svg>
                </button>

                @if (_filterableColumns is { Count: > 0 })
                {
                    <button class="grid-toolbar-icon @(DataRepository.FilterColumns.Count > 0 ? "pressed" : "")" @onclick="OpenFilterModal" aria-label="Filter">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3" />
                        </svg>
                    </button>
                }

                <button class="grid-toolbar-icon @(_columnsPressed ? "pressed" : "")" @onclick="OpenColumnsModal" aria-label="Columns">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="3" y="3" width="7" height="18" rx="1" />
                        <rect x="14" y="3" width="7" height="18" rx="1" />
                    </svg>
                </button>

                @if (_rowActions is { Count: > 0 })
                {
                    <div class="grid-context-menu-wrapper">
                        <button class="grid-toolbar-icon"
                                disabled="@(_selectedRow is null)"
                                @onclick="ToggleContextMenu"
                                @onclick:stopPropagation="true"
                                aria-label="Context menu">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <circle cx="12" cy="5" r="1" />
                                <circle cx="12" cy="12" r="1" />
                                <circle cx="12" cy="19" r="1" />
                            </svg>
                        </button>
                        @if (_showContextMenu)
                        {
                            <div class="grid-context-backdrop" @onclick="CloseContextMenu"></div>
                            <div class="grid-context-dropdown">
                                @foreach (var action in _rowActions)
                                {
                                    <button class="grid-context-item" @onclick="() => OnContextAction(action)">@action</button>
                                }
                            </div>
                        }
                    </div>
                }
            </div>

            @if (_gridActions is { Count: > 0 })
            {
                <div class="grid-actions-right">
                    @foreach (var action in _gridActions)
                    {
                        <button class="grid-action-btn-top" @onclick="() => OnGridAction(action)">@action</button>
                    }
                </div>
            }
        </div>

        <div class="grid-table-wrapper">
            <table class="grid-table grid-table-fixed" style="@(_useFixedWidths ? $"width: {GetTotalTableWidth()}px" : "")">
                @if (_useFixedWidths)
                {
                    <colgroup>
                        @foreach (var col in VisibleColumns)
                        {
                            <col style="width: @(GetColumnWidth(col))px" />
                        }
                    </colgroup>
                }
                <thead>
                    <tr>
                        @for (var i = 0; i < VisibleColumns.Count; i++)
                        {
                            var colIdx = i;
                            var col = VisibleColumns[colIdx];
                            <th>
                                <span class="grid-th-text grid-th-sortable" @onclick="() => ToggleSortAsync(col)">
                                    @col
                                    @if (_sortColumnName == col)
                                    {
                                        @if (_sortDirection == "asc")
                                        {
                                            <svg class="grid-sort-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                                <polyline points="6 15 12 9 18 15" />
                                            </svg>
                                        }
                                        else
                                        {
                                            <svg class="grid-sort-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                                <polyline points="6 9 12 15 18 9" />
                                            </svg>
                                        }
                                    }
                                </span>
                                @if (colIdx < VisibleColumns.Count - 1)
                                {
                                    <div class="grid-col-delimiter"
                                         @onmousedown="(e) => StartColumnResize(e, colIdx)"
                                         @onmousedown:preventDefault="true"
                                         @onmousedown:stopPropagation="true"></div>
                                }
                            </th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @if (_isLoading)
                    {
                        @for (var s = 0; s < _pageSize; s++)
                        {
                            <tr class="grid-skeleton-row">
                                @foreach (var col in VisibleColumns)
                                {
                                    <td>
                                        <div class="grid-skeleton-cell" style="width: @(50 + (s + col.Length) % 4 * 12)%"></div>
                                    </td>
                                }
                            </tr>
                        }
                    }
                    else if (_data is null || _data.Count == 0)
                    {
                        <tr>
                            <td colspan="@VisibleColumns.Count" class="grid-empty">No data available.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var row in _data)
                        {
                            <tr @key="row"
                                class="@(ReferenceEquals(row, _selectedRow) ? "grid-row-selected" : "")"
                                @onclick="() => SelectRow(row)">
                                @foreach (var col in VisibleColumns)
                                {
                                    <td data-label="@col">@GetCellValue(row, col)</td>
                                }
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <div class="grid-footer">
            <span class="grid-footer-label">Show</span>
            <select class="grid-footer-select" value="@_pageSize" @onchange="OnPageSizeChanged">
                @foreach (var size in PageSizeOptions)
                {
                    <option value="@size">@size</option>
                }
            </select>
            <span class="grid-footer-label">rows</span>
        </div>
    }

    @if (_isDragging)
    {
        <div class="grid-resize-overlay"
             @onmousemove="OnResizeMove"
             @onmouseup="OnResizeEnd"
             @onmousemove:preventDefault="true"></div>
    }

    @if (_showFilterModal && _filterRows is not null)
    {
        <div class="grid-modal-backdrop" @onclick="CloseFilterModal">
            <div class="grid-modal" @onclick:stopPropagation="true">
                <div class="grid-modal-header">
                    <h3>Filter</h3>
                    <button class="grid-modal-close" @onclick="CloseFilterModal" aria-label="Close">&times;</button>
                </div>
                <div class="grid-modal-body">
                    <table class="grid-filter-table">
                        <thead>
                            <tr>
                                <th>Column</th>
                                <th>Condition</th>
                                <th>Value</th>
                            </tr>
                        </thead>
                        <tbody>
                            @for (var i = 0; i < _filterRows.Length; i++)
                            {
                                var index = i;
                                <tr>
                                    <td class="grid-filter-col-name">@_filterRows[index].Column</td>
                                    <td>
                                        <select class="grid-filter-select"
                                                value="@_filterRows[index].Operator"
                                                @onchange="(e) => OnOperatorChanged(e, index)">
                                            <option value="Equal">Equal</option>
                                            <option value="NotEqual">Not Equal</option>
                                            <option value="Contains">Contains</option>
                                            <option value="GreaterThan">Greater Than</option>
                                            <option value="LessThan">Less Than</option>
                                            <option value="GreaterThanOrEqual">&ge; (GTE)</option>
                                            <option value="LessThanOrEqual">&le; (LTE)</option>
                                        </select>
                                    </td>
                                    <td>
                                        <input class="grid-filter-input" type="text"
                                               value="@_filterRows[index].Value"
                                               @onchange="(e) => OnValueChanged(e, index)" />
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <div class="grid-modal-footer">
                    <button class="grid-modal-btn grid-modal-btn-clear" @onclick="ClearFilterValues">Clear</button>
                    <button class="grid-modal-btn grid-modal-btn-save" @onclick="SaveFiltersAsync">Save</button>
                </div>
            </div>
        </div>
    }

    @if (_showColumnsModal && _columnCheckboxes is not null)
    {
        <div class="grid-modal-backdrop" @onclick="CloseColumnsModal">
            <div class="grid-modal" @onclick:stopPropagation="true">
                <div class="grid-modal-header">
                    <h3>Columns</h3>
                    <button class="grid-modal-close" @onclick="CloseColumnsModal" aria-label="Close">&times;</button>
                </div>
                <div class="grid-modal-body">
                    <div class="grid-columns-list">
                        @for (var i = 0; i < _columnCheckboxes.Length; i++)
                        {
                            var index = i;
                            <label class="grid-columns-item">
                                <input type="checkbox"
                                       checked="@_columnCheckboxes[index].Checked"
                                       @onchange="(e) => OnColumnChecked(e, index)" />
                                <span>@_columnCheckboxes[index].Name</span>
                            </label>
                        }
                    </div>
                </div>
                <div class="grid-modal-footer">
                    <button class="grid-modal-btn grid-modal-btn-save"
                            disabled="@(!_columnCheckboxes.Any(c => c.Checked))"
                            @onclick="SaveColumns">Save</button>
                </div>
            </div>
        </div>
    }

    @if (_showActionModal && _actionFields is not null)
    {
        <div class="grid-modal-backdrop" @onclick="CloseActionModal">
            <div class="grid-modal" @onclick:stopPropagation="true">
                <div class="grid-modal-header">
                    <h3>@_actionName</h3>
                    <button class="grid-modal-close" @onclick="CloseActionModal" aria-label="Close">&times;</button>
                </div>
                <div class="grid-modal-body">
                    <div class="grid-action-form">
                        @for (var i = 0; i < _actionFields.Length; i++)
                        {
                            var index = i;
                            var field = _actionFields[index];
                            <div class="grid-action-field">
                                <label class="grid-action-label">@field.Name</label>
                                @if (field.Visual == "label")
                                {
                                    <span class="grid-action-value-label">@field.Value</span>
                                }
                                else if (field.PossibleValues.Count > 0)
                                {
                                    <select class="grid-action-select"
                                            value="@field.Value"
                                            @onchange="(e) => OnActionFieldChanged(e, index)">
                                        @foreach (var opt in field.PossibleValues)
                                        {
                                            <option value="@opt.Id">@opt.Text</option>
                                        }
                                    </select>
                                }
                                else
                                {
                                    <input class="grid-action-input @(field.Error is not null ? "grid-action-input-error" : "")"
                                           type="text"
                                           value="@field.Value"
                                           @onchange="(e) => OnActionFieldChanged(e, index)" />
                                }
                                @if (field.Error is not null)
                                {
                                    <span class="grid-action-error">@field.Error</span>
                                }
                            </div>
                        }
                    </div>
                </div>
                <div class="grid-modal-footer">
                    <button class="grid-modal-btn grid-modal-btn-clear" @onclick="CloseActionModal">Cancel</button>
                    <button class="grid-modal-btn grid-modal-btn-save"
                            disabled="@HasActionErrors"
                            @onclick="SubmitActionAsync">Ok</button>
                </div>
            </div>
        </div>
    }
</div>

@typeparam T where T : class

@code {
    [Parameter, EditorRequired]
    public IGridDataRepository<T> DataRepository { get; set; } = default!;

    [Parameter]
    public int PageSize { get; set; } = 10;

    private int _pageSize;
    private static readonly int[] PageSizeOptions = [10, 20, 50, 100];

    private IReadOnlyList<string>? _columns;
    private IReadOnlyList<string>? _filterableColumns;
    private IReadOnlyList<string>? _rowActions;
    private IReadOnlyList<string>? _gridActions;
    private List<T>? _data;
    private Dictionary<string, PropertyInfo>? _propertyCache;
    private int _currentPage = 1;
    private bool _hasNextPage;
    private bool _isLoading;
    private T? _selectedRow;

    public List<string> VisibleColumns { get; private set; } = [];

    private bool _columnsPressed;

    private string? _sortColumnName;
    private string? _sortDirection;

    private bool _showFilterModal;
    private FilterRowModel[]? _filterRows;

    private bool _showColumnsModal;
    private ColumnCheckbox[]? _columnCheckboxes;

    private bool _showContextMenu;

    private Dictionary<string, int> _columnWidths = new();
    private bool _useFixedWidths;
    private bool _isDragging;
    private int _dragColumnIndex;
    private double _dragStartX;
    private int _dragStartWidth;
    private const int MinColumnWidth = 50;

    private bool _showActionModal;
    private string _actionName = string.Empty;
    private ActionFieldModel[]? _actionFields;
    private bool _isGridAction;

    private class ActionFieldModel
    {
        public string Name { get; set; } = string.Empty;
        public string Value { get; set; } = string.Empty;
        public IReadOnlyList<(string Id, string Text)> PossibleValues { get; set; } = [];
        public string Visual { get; set; } = "textbox";
        public Type? PropertyType { get; set; }
        public string? Error { get; set; }
    }

    private class FilterRowModel
    {
        public string Column { get; set; } = string.Empty;
        public string Operator { get; set; } = "Equal";
        public string Value { get; set; } = string.Empty;
    }

    private class ColumnCheckbox
    {
        public string Name { get; set; } = string.Empty;
        public bool Checked { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        _columns = DataRepository.GetColumnNames();
        _filterableColumns = DataRepository.Capabilities.Filter;
        _rowActions = DataRepository.Capabilities.RowActions;
        _gridActions = DataRepository.Capabilities.GridActions;
        VisibleColumns = new List<string>(_columns);
        var gridId = typeof(T).FullName ?? typeof(T).Name;
        var savedWidths = GridState.GetColumnWidths(gridId);
        if (savedWidths is not null)
        {
            foreach (var col in _columns)
                _columnWidths[col] = savedWidths.TryGetValue(col, out var w) ? w : ComputeDefaultColumnWidth();
            _useFixedWidths = true;
        }
        var savedSort = GridState.GetSortColumn(gridId);
        if (savedSort is not null)
        {
            _sortColumnName = savedSort.Column;
            _sortDirection = savedSort.Direction;
            DataRepository.SortColumn = savedSort;
        }
        _pageSize = GridState.GetPageSize(gridId) ?? PageSize;
        _propertyCache = typeof(T)
            .GetProperties(BindingFlags.Public | BindingFlags.Instance)
            .Where(p => _columns.Contains(p.Name))
            .ToDictionary(p => p.Name);

        await LoadPageAsync();
    }

    private async Task LoadPageAsync()
    {
        _isLoading = true;
        _selectedRow = null;
        _showContextMenu = false;
        StateHasChanged();

        var results = await DataRepository.GetDataAsync(_currentPage, _pageSize);
        _data = results;
        _hasNextPage = results.Count == _pageSize;

        _isLoading = false;
    }

    private async Task NextPageAsync()
    {
        _currentPage++;
        await LoadPageAsync();
    }

    private async Task PreviousPageAsync()
    {
        if (_currentPage > 1)
        {
            _currentPage--;
            await LoadPageAsync();
        }
    }

    private async Task OnPageSizeChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var size))
        {
            _pageSize = size;
            _currentPage = 1;
            GridState.SavePageSize(typeof(T).FullName ?? typeof(T).Name, _pageSize);
            await LoadPageAsync();
        }
    }

    private void SelectRow(T row)
    {
        _selectedRow = row;
        _showContextMenu = false;
    }

    private void OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Escape")
        {
            _showContextMenu = false;
            _selectedRow = null;
        }
    }

    // --- Sorting ---

    private async Task ToggleSortAsync(string column)
    {
        if (_sortColumnName == column)
        {
            _sortDirection = _sortDirection switch
            {
                "asc" => "desc",
                "desc" => null,
                _ => "asc"
            };
            if (_sortDirection is null)
                _sortColumnName = null;
        }
        else
        {
            _sortColumnName = column;
            _sortDirection = "asc";
        }

        DataRepository.SortColumn = _sortColumnName is not null
            ? new GridSortColumn(_sortColumnName, _sortDirection!)
            : null;

        GridState.SaveSortColumn(typeof(T).FullName ?? typeof(T).Name, DataRepository.SortColumn);

        _currentPage = 1;
        await LoadPageAsync();
    }

    // --- Context menu ---

    private void ToggleContextMenu() => _showContextMenu = !_showContextMenu;

    private void CloseContextMenu() => _showContextMenu = false;

    private void OnContextAction(string action)
    {
        _showContextMenu = false;
        if (_selectedRow is null) return;

        var details = DataRepository.RowActionDetails(action, _selectedRow);
        OpenActionForm(action, details, isGridAction: false);
    }

    private void OnGridAction(string action)
    {
        var details = DataRepository.GridActionDetails(action);
        OpenActionForm(action, details, isGridAction: true);
    }

    private void OpenActionForm(string action, IReadOnlyList<RowActionField> details, bool isGridAction)
    {
        _actionFields = details.Select(f =>
        {
            Type? propType = null;
            if (_propertyCache is not null && _propertyCache.TryGetValue(f.Name, out var prop))
                propType = Nullable.GetUnderlyingType(prop.PropertyType) ?? prop.PropertyType;

            return new ActionFieldModel
            {
                Name = f.Name,
                Value = f.Value,
                PossibleValues = f.PossibleValues,
                Visual = f.Visual,
                PropertyType = propType
            };
        }).ToArray();

        _actionName = action;
        _isGridAction = isGridAction;
        _showActionModal = true;
    }

    private void CloseActionModal() => _showActionModal = false;

    private void OnActionFieldChanged(ChangeEventArgs e, int index)
    {
        var field = _actionFields![index];
        field.Value = e.Value?.ToString() ?? string.Empty;
        RunValidation();
    }

    private void RunValidation()
    {
        if (_actionFields is null) return;

        foreach (var field in _actionFields)
            field.Error = ValidateFieldType(field);

        if (_actionFields.Any(f => f.Error is not null))
            return;

        var validator = DataRepository.GetValidator;
        if (validator is null || _propertyCache is null)
            return;

        var temp = Activator.CreateInstance<T>();
        if (!_isGridAction && _selectedRow is not null)
        {
            foreach (var prop in _propertyCache.Values)
            {
                var original = prop.GetValue(_selectedRow);
                prop.SetValue(temp, original);
            }
        }

        foreach (var field in _actionFields)
        {
            if (field.Visual == "label") continue;
            if (!_propertyCache.TryGetValue(field.Name, out var prop)) continue;
            try
            {
                var targetType = Nullable.GetUnderlyingType(prop.PropertyType) ?? prop.PropertyType;
                if (string.IsNullOrWhiteSpace(field.Value) && Nullable.GetUnderlyingType(prop.PropertyType) is not null)
                    prop.SetValue(temp, null);
                else
                {
                    var converted = Convert.ChangeType(field.Value, targetType,
                        System.Globalization.CultureInfo.InvariantCulture);
                    prop.SetValue(temp, converted);
                }
            }
            catch { }
        }

        var result = validator.Validate(temp);
        if (!result.IsValid)
        {
            foreach (var err in result.Errors)
            {
                var match = _actionFields.FirstOrDefault(f => f.Name == err.PropertyName);
                if (match is not null && match.Visual != "label")
                    match.Error = err.ErrorMessage;
            }
        }
    }

    private static string? ValidateFieldType(ActionFieldModel field)
    {
        if (field.Visual == "label" || field.PossibleValues.Count > 0 || field.PropertyType is null)
            return null;

        var val = field.Value;
        if (string.IsNullOrWhiteSpace(val))
            return null;

        var type = field.PropertyType;
        if (type == typeof(int) && !int.TryParse(val, System.Globalization.NumberStyles.Integer,
                System.Globalization.CultureInfo.InvariantCulture, out _))
            return "Must be a whole number";
        if (type == typeof(long) && !long.TryParse(val, System.Globalization.NumberStyles.Integer,
                System.Globalization.CultureInfo.InvariantCulture, out _))
            return "Must be a whole number";
        if (type == typeof(double) && !double.TryParse(val, System.Globalization.NumberStyles.Float,
                System.Globalization.CultureInfo.InvariantCulture, out _))
            return "Must be a number";
        if (type == typeof(decimal) && !decimal.TryParse(val, System.Globalization.NumberStyles.Float,
                System.Globalization.CultureInfo.InvariantCulture, out _))
            return "Must be a number";
        if (type == typeof(DateTime) && !DateTime.TryParse(val,
                System.Globalization.CultureInfo.InvariantCulture,
                System.Globalization.DateTimeStyles.None, out _))
            return "Must be a valid date";

        return null;
    }

    private bool HasActionErrors =>
        _actionFields?.Any(f => f.Error is not null) == true;

    private async Task SubmitActionAsync()
    {
        if (_actionFields is null) return;

        T target;
        if (_isGridAction)
        {
            target = Activator.CreateInstance<T>();
        }
        else
        {
            if (_selectedRow is null) return;
            target = _selectedRow;
        }

        foreach (var field in _actionFields)
        {
            if (field.Visual == "label") continue;
            if (_propertyCache is not null && _propertyCache.TryGetValue(field.Name, out var prop))
            {
                try
                {
                    var targetType = Nullable.GetUnderlyingType(prop.PropertyType) ?? prop.PropertyType;
                    if (string.IsNullOrWhiteSpace(field.Value) && Nullable.GetUnderlyingType(prop.PropertyType) is not null)
                        prop.SetValue(target, null);
                    else
                    {
                        var converted = Convert.ChangeType(field.Value, targetType,
                            System.Globalization.CultureInfo.InvariantCulture);
                        prop.SetValue(target, converted);
                    }
                }
                catch { }
            }
        }

        await DataRepository.InvokeAction(_actionName, target);
        _showActionModal = false;
        await LoadPageAsync();
    }

    // --- Filter modal ---

    private void OpenFilterModal()
    {
        if (_filterableColumns is null) return;

        var existing = DataRepository.FilterColumns
            .ToDictionary(f => f.Column, f => f);

        _filterRows = _filterableColumns.Select(col =>
        {
            if (existing.TryGetValue(col, out var fc))
                return new FilterRowModel { Column = col, Operator = fc.Operator, Value = fc.Value };
            return new FilterRowModel { Column = col };
        }).ToArray();

        _showFilterModal = true;
    }

    private void CloseFilterModal() => _showFilterModal = false;

    private void OnOperatorChanged(ChangeEventArgs e, int index)
    {
        _filterRows![index].Operator = e.Value?.ToString() ?? "Equal";
    }

    private void OnValueChanged(ChangeEventArgs e, int index)
    {
        _filterRows![index].Value = e.Value?.ToString() ?? string.Empty;
    }

    private void ClearFilterValues()
    {
        if (_filterRows is null) return;
        foreach (var row in _filterRows)
        {
            row.Value = string.Empty;
        }
    }

    private async Task SaveFiltersAsync()
    {
        DataRepository.FilterColumns.Clear();
        if (_filterRows is not null)
        {
            foreach (var row in _filterRows)
            {
                if (!string.IsNullOrWhiteSpace(row.Value))
                    DataRepository.FilterColumns.Add(new FilterColumn(row.Column, row.Operator, row.Value));
            }
        }

        _showFilterModal = false;
        _currentPage = 1;
        await LoadPageAsync();
    }

    // --- Columns modal ---

    private void OpenColumnsModal()
    {
        if (_columns is null) return;

        var visibleSet = new HashSet<string>(VisibleColumns);
        _columnCheckboxes = _columns.Select(col =>
            new ColumnCheckbox { Name = col, Checked = visibleSet.Contains(col) }
        ).ToArray();

        _showColumnsModal = true;
    }

    private void CloseColumnsModal() => _showColumnsModal = false;

    private void OnColumnChecked(ChangeEventArgs e, int index)
    {
        _columnCheckboxes![index].Checked = e.Value is true;
    }

    private void SaveColumns()
    {
        if (_columnCheckboxes is not null)
        {
            VisibleColumns = _columnCheckboxes
                .Where(c => c.Checked)
                .Select(c => c.Name)
                .ToList();
        }

        _columnsPressed = _columns is not null
            && VisibleColumns.Count != _columns.Count;

        _showColumnsModal = false;
    }

    private string GetCellValue(T row, string columnName)
    {
        if (_propertyCache is null || !_propertyCache.TryGetValue(columnName, out var prop))
            return string.Empty;

        var value = prop.GetValue(row);
        return value switch
        {
            DateTime dt => dt.ToShortDateString(),
            null => string.Empty,
            _ => value.ToString() ?? string.Empty
        };
    }

    // --- Column resize ---

    private int ComputeDefaultColumnWidth() =>
        Math.Clamp(1200 / Math.Max(1, VisibleColumns.Count), MinColumnWidth, 400);

    private int GetColumnWidth(string col) =>
        _columnWidths.TryGetValue(col, out var w) ? w : ComputeDefaultColumnWidth();

    private int GetTotalTableWidth() =>
        VisibleColumns.Sum(c => GetColumnWidth(c));

    private void StartColumnResize(MouseEventArgs e, int colIndex)
    {
        if (!_useFixedWidths)
        {
            var defaultWidth = ComputeDefaultColumnWidth();
            foreach (var col in _columns!)
                _columnWidths[col] = defaultWidth;
            _useFixedWidths = true;
        }

        _isDragging = true;
        _dragColumnIndex = colIndex;
        _dragStartX = e.ClientX;
        _dragStartWidth = GetColumnWidth(VisibleColumns[colIndex]);
    }

    private void OnResizeMove(MouseEventArgs e)
    {
        if (!_isDragging) return;
        var newWidth = (int)(_dragStartWidth + (e.ClientX - _dragStartX));
        _columnWidths[VisibleColumns[_dragColumnIndex]] = Math.Max(MinColumnWidth, newWidth);
    }

    private void OnResizeEnd(MouseEventArgs e)
    {
        _isDragging = false;
        GridState.SaveColumnWidths(typeof(T).FullName ?? typeof(T).Name, _columnWidths);
    }
}
